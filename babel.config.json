{
  "plugins": [
    ["@babel/plugin-proposal-decorators", {"version": "2023-11", "decoratorsBeforeExport": true}],
    ["@babel/plugin-transform-react-constant-elements"]
  ],
  "presets": [
    [
      "@babel/preset-env",
      {
        "targets": "defaults",
        "modules": false
      }
    ],
    "@babel/preset-react"
  ]
}